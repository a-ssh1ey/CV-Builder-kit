<style>
    .education-section {
        max-width: 330px;
        margin-bottom: var(--spacing-section);
    }
    .education-section .title {
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 2px solid var(--color-primary);
        font-size: var(--font-size-section-title);
        font-weight: var(--font-weight-bold);
        line-height: 1.2;
        color: var(--color-primary);
        text-transform: uppercase;
    }
    .education-section .education-item {
        margin-bottom: 8px;
    }
    .education-section .education-header {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 3px;
        font-size: var(--font-size-medium);
        line-height: 1.25;
        color: var(--color-text-main);
    }
    .education-section .degree {
        font-weight: var(--font-weight-bold);
    }
    .education-section .university {
        font-size: 12px;
        font-weight: var(--font-weight-semibold);
        color: var(--color-primary);
    }
    .education-section .years {
        font-size: 12px;
        color: var(--color-text-muted);
    }
    .education-section .separator {
        color: var(--color-text-muted);
    }
    .education-section .comment,
    .education-section .university-comment {
        font-size: var(--font-size-medium);
        line-height: 1.3;
        color: var(--color-text-secondary);
    }
</style>
<div class="education-section">
    <div class="title">{{ local.education.title }}</div>
    {% for group in local.education.groups %}
        <div class="education-item">
            <div class="education-header">
                <div class="degree">{{ group.title }}</div>
                <span class="separator">|</span>
                <div class="university">{{ group.university }}</div>
                <span class="separator">|</span>
                <div class="years">
                    <i>{{ group.years }}</i>
                </div>
            </div>
            {% if group.university_comment %}
                <div class="university-comment">{{ group.university_comment }}</div>
            {% endif %}
            {% if group.comment %}
                <div class="comment">{{ group.comment }}</div>
            {% endif %}
        </div>
    {% endfor %}
</div>