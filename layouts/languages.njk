<style>
    .languages-section {
        width: 350px;
        margin-bottom: var(--spacing-section);
    }
    .languages-section .title {
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 2px solid var(--color-primary);
        font-size: var(--font-size-section-title);
        font-weight: var(--font-weight-bold);
        line-height: 1.2;
        color: var(--color-primary);
        text-transform: uppercase;
    }
    .languages-section .language-item {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 4px;
        font-size: var(--font-size-medium);
        line-height: 1.3;
        color: var(--color-text-secondary);
    }
    .languages-section .language-name {
        font-weight: var(--font-weight-bold);
        color: var(--color-text-main);
    }
    .languages-section .language-level {
        font-weight: var(--font-weight-semibold);
        color: var(--color-primary);
    }
    .languages-section .language-comment {
        color: var(--color-text-muted);
    }
    .languages-section .separator {
        color: var(--color-text-muted);
    }
</style>
<div class="languages-section">
    <div class="title">{{ local.languages.title }}</div>
    {% for item in local.languages.languages %}
        <div class="language-item">
            <span class="language-name">{{ item.title }}</span>
            <span class="language-name">{{ item.language }}</span>
            <span class="separator">
                -
            </span>
            <span class="language-level">{{ item.level }}</span>
            {% if item.comment %}
                <span class="separator">|</span>
                <span class="language-comment">{{ item.comment }}</span>
            {% endif %}
        </div>
    {% endfor %}
</div>