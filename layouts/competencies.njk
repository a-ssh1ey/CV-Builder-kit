<style>
    .competencies-section {
        max-width: 330px;
        margin-bottom: var(--spacing-section);
    }
    .competencies-section .title {
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 2px solid var(--color-primary);
        font-size: var(--font-size-section-title);
        font-weight: var(--font-weight-bold);
        line-height: 1.2;
        color: var(--color-primary);
        text-transform: uppercase;
    }
    .competencies-section .competency {
        display: flex;
        align-items: flex-start;
        gap: 6px;
        margin-bottom: 3px;
        font-size: var(--font-size-medium);
        line-height: 1.3;
        color: var(--color-text-secondary);
    }
    .competencies-section .competency-marker {
        flex: 0 0 auto;
        margin-top: 1px;
        font-size: 10px;
        line-height: 1.3;
        color: var(--color-primary);
    }
</style>
<div class="competencies-section">
    <div class="title">{{ local.competencies.title }}</div>
    {% for competency in local.competencies.competencies %}
        <div class="competency">
            <span class="competency-marker">▸</span>
            <span>{{ competency }}</span>
        </div>
    {% endfor %}
</div>