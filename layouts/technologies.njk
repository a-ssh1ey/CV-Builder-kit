<style>
    .technologies-section {
        width: 350px;
        margin-bottom: var(--spacing-section);
    }
    .technologies-section .title {
        margin-bottom: 8px;
        padding-bottom: 3px;
        border-bottom: 2px solid var(--color-primary);
        font-size: var(--font-size-section-title);
        font-weight: var(--font-weight-bold);
        line-height: 1.2;
        color: var(--color-primary);
        text-transform: uppercase;
    }
    .technologies-section .group {
        margin-bottom: 7px;
    }
    .technologies-section .group-title {
        margin-bottom: 3px;
        font-size: var(--font-size-medium);
        font-weight: var(--font-weight-bold);
        color: var(--color-text-main);
    }
    .technologies-section .tools {
        display: flex;
        flex-wrap: wrap;
        gap: 4px 6px;
        font-size: var(--font-size-medium);
        line-height: 1.3;
        color: var(--color-text-secondary);
    }
    .technologies-section .tool {
        display: inline;
    }
    .technologies-section .separator {
        color: var(--color-primary);
    }
</style>
<div class="technologies-section">
    <div class="title">{{ local.tools.title }}</div>
    {% for group in local.tools.groups %}
        <div class="group">
            <div class="group-title">{{ group.title }}</div>
            <div class="tools">
                {% for item in group.items %}
                    <span class="tool">{{ item }}</span>
                    {% if not loop.last %}
                        <span class="separator">•</span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endfor %}
</div>